{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "PDFit",
  "version": "0.1.0",
  "identifier": "com.pdfit.desktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:5173",
    "beforeBuildCommand": "VITE_BASE=/ npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "PDFit",
        "width": 1200,
        "height": 800,
        "minWidth": 800,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": "default-src 'self' 'unsafe-inline' 'unsafe-eval' data: blob: asset: https:; img-src 'self' data: blob: asset: https:; style-src 'self' 'unsafe-inline' https:; script-src 'self' 'unsafe-inline' 'unsafe-eval' https:;",
      "assetProtocol": {
        "enable": true,
        "scope": ["$APPDATA/pdfit/*", "$DESKTOP/*", "$DOCUMENTS/*", "$DOWNLOAD/*", "$HOME/*", "$LOCALAPPDATA/*", "$TEMP/*", "$APPDATA/**/*"]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "wix": {
        "language": ["zh-CN", "en-US"]
      }
    },
    "fileAssociations": [
      {
        "name": "PDF Document",
        "ext": ["pdf"],
        "mimeType": "application/pdf",
        "role": "Viewer"
      }
    ],
    "macOS": {
      "minimumSystemVersion": "12.0"
    },
    "linux": {
      "deb": {
        "depends": ["libasound2"]
      }
    }
  },
  "plugins": {
    "updater": {
      "active": true,
      "endpoints": [
        "https://api.github.com/repos/asteriya-phd/PDFit/releases/latest"
      ],
      "dialog": true,
      "pubkey": ""
    }
  }
}